{
  "ConnectionStrings": {
    "Postgres": "Server=localhost;Database=crypto_watcher.stage;User Id=postgres;Password=admin;Include Error Detail = true",
    "Redis": "localhost:6379"
  },
  "ExternalServicesConfig": {
    "CoinGecko": "https://api.coingecko.com",
    "Uniswap": "https://interface.gateway.uniswap.org",
    "Morpho" : "https://api.morpho.org/graphql"
  },
  "AaveConfig": {
    "SonicMainnetAddress" : "https://rpc.soniclabs.com",
    "CelloMainnetAddress": "https://forno.celo.org",
    "AvalancheMainnetAddress": "https://api.avax.network/ext/bc/C/rpc"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "CryptoWatcher"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": {
      "ConsoleSink": {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}][{Level:u3}] [{SourceContext}] {Message:lj} {NewLine}{Exception}"
        }
      },
      "FileSink": {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    }
  }
}
