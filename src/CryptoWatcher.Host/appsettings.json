{
  "ConnectionStrings": {
    "Postgres": "Server=localhost;Database=crypto_watcher.stage;User Id=postgres;Password=admin;Include Error Detail = true",
    "Hangfire": "Server=localhost;Database=hangfire.stage;User Id=postgres;Password=admin;Include Error Detail = true",
    "Redis": "localhost:6379"
  },
  "ExternalServicesConfig": {
    "CoinGecko": "https://api.coingecko.com",
    "Morpho" : "https://api.morpho.org/graphql",
    "Merkl": "https://api.merkl.xyz",
    "Otel": "http://192.168.50.188:4317"
  },
  "KafkaConfig": {
    "Host": "192.168.50.188:9092", 
    "RawTransactionsTopic": "transactions.raw",
    "UniswapConsumerGroupId": "uniswap"
  },
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "CryptoWatcher"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}][{Level:u3}] [{SourceContext}] {Message:lj} {NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}
